# ─── DATABASE ───────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/agentmarket?schema=public"

# ─── AUTH ───────────────────────────────────────────────────
JWT_SECRET="replace-with-32-plus-char-random-string"
JWT_EXPIRES_IN="7d"

# ─── OKX ONCHAIN OS ─────────────────────────────────────────
# Get from: https://web3.okx.com/onchainos/dev-portal
OKX_API_KEY="your-okx-api-key"
OKX_SECRET_KEY="your-okx-secret-key"
OKX_PASSPHRASE="your-okx-passphrase"
OKX_PROJECT_ID="your-okx-project-id"

# ─── X LAYER BLOCKCHAIN ─────────────────────────────────────
X_LAYER_RPC_URL="https://rpc.xlayer.tech"
X_LAYER_CHAIN_ID="196"
# Platform fee collection wallet (generate new, fund with OKB for gas)
PLATFORM_PRIVATE_KEY="0x..."
PLATFORM_WALLET_ADDRESS="0x..."

# ─── CONTRACTS ──────────────────────────────────────────────
# USDC on X Layer mainnet
USDC_CONTRACT_ADDRESS="0x74b7F16337b8972027F6196A17a631aC6dE26d22"
# AgentRegistry — deploy with: npx hardhat run scripts/deploy.ts
AGENT_REGISTRY_ADDRESS="0x..."

# ─── EMAIL ──────────────────────────────────────────────────
# Get from: https://resend.com (free: 3,000 emails/month)
RESEND_API_KEY="re_..."

# ─── MONITORING ─────────────────────────────────────────────
# Get from: https://sentry.io (free tier available)
SENTRY_DSN="https://...@sentry.io/..."
# Platform takes 5% of every call
PLATFORM_FEE_BPS="500"

# ─── SERVER ─────────────────────────────────────────────────
PORT="4000"
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"
