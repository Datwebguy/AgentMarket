{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "env": {
    "NEXT_PUBLIC_API_URL":           "@agentmarket_api_url",
    "NEXT_PUBLIC_X_LAYER_CHAIN_ID":  "196",
    "NEXT_PUBLIC_X_LAYER_RPC_URL":   "https://rpc.xlayer.tech",
    "NEXT_PUBLIC_X_LAYER_EXPLORER":  "https://www.oklink.com/xlayer",
    "NEXT_PUBLIC_USDC_ADDRESS":      "0x74b7F16337b8972027F6196A17a631aC6dE26d22",
    "NEXT_PUBLIC_REGISTRY_ADDRESS":  "@agentmarket_registry_address",
    "NEXT_PUBLIC_APP_URL":           "@agentmarket_app_url"
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PATCH,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Authorization,X-Payment" }
      ]
    }
  ]
}
